@page
@model StudentManagerWebApp.Pages.Teachers.IndexModel

<h2>Teachers</h2>
<p>
    <a asp-page="Create" class="btn btn-primary">Add Teacher</a>
    <a asp-page="/Dashboard" class="btn btn-secondary">Back to Dashboard</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Department</th>
            <th>Courses</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var teacher in Model.Teachers)
        {
            <tr>
                <td>@teacher.FirstName @teacher.LastName</td>
                <td>@teacher.AppUser?.Email</td>
                <td>@teacher.Department</td>
                <td>@teacher.Courses.Count</td>
                <td>
                    <a asp-page="Edit" asp-route-id="@teacher.Id" class="btn btn-sm btn-primary">Edit</a>
                </td>
            </tr>
        }
    </tbody>
</table>
