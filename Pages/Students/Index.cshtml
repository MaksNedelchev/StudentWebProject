@page
@model StudentManagerWebApp.Pages.Students.IndexModel
@{
}

<h2>Students</h2>
<a asp-page="Create" class="btn btn-light">Add Student</a>
<table class="table">
    <thead>
        <tr>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Date Enrolled</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach(var student in Model.Students)
        {
            <tr>
                <td>@student.FirstName</td>
                <td>@student.LastName</td>
                <td>@student.EnrollmentDate</td>
                <td>
                    <a asp-page="Enrollments" asp-route-id="@student.Id" class="btn btn-primary">View Enrollments</a>
                    <a asp-page="Edit" asp-route-id="@student.Id" class="btn btn-primary">Edit</a>
                    <a asp-page="Delete" asp-route-id="@student.Id" class="btn btn-primary">Delete</a>
                    </td>
            </tr>
        }
    </tbody>
</table>
