@page
@model StudentManagerWebApp.Pages.Students.CreateModel
@{
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <h2 class="mb-4">Add a student</h2>
        <form method="post">
            <div class="mb-3">
                <label asp-for="Student.FirstName" class="form-label"></label>
                <input asp-for="Student.FirstName" class="form-control" />
                <span asp-validation-for="Student.FirstName" class="alert text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Student.LastName" class="form-label"></label>
                <input asp-for="Student.LastName" class="form-control" />
                <span asp-validation-for="Student.LastName" class="alert text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Student.EnrollmentDate" class="form-label"></label>
                <input asp-for="Student.EnrollmentDate" min="2018-01-01" class="form-control" />
                <span asp-validation-for="Student.EnrollmentDate" class="alert text-danger"></span>
            </div>
            <button type="submit" class="btn btn-primary">Add</button>
            <a asp-page="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>
