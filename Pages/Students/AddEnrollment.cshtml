@page "{id:int}"
@model StudentManagerWebApp.Pages.Students.AddEnrollmentModel

<h2>Add Enrollment for @Model.Student.FirstName @Model.Student.LastName</h2>

<form method="post" asp-route-id="@Model.StudentId">
    <input asp-for="StudentId" type="hidden" />

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="d-flex flex-wrap gap-2 mb-3">
        <a asp-page="/Courses/Create" class="btn btn-outline-primary btn-sm">Add new course</a>
        <a asp-page="/Students/Enrollments" asp-route-id="@Model.Student.Id" class="btn btn-outline-secondary btn-sm">Back to enrollments</a>
    </div>

    @if (!Model.AllCourses.Any())
    {
        <div class="alert alert-info">This student is already enrolled in every available course.</div>
    }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th></th>
                    <th>Course</th>
                    <th>Hours</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var course in Model.AllCourses)
                {
                <tr>
                    <td>
                        <input type="checkbox" name="SelectedCoursesIds" value="@course.Id" />
                    </td>
                    <td>@course.Title</td>
                    <td>@course.Hours</td>
                </tr>
                }
            </tbody>
        </table>
    }

    <button type="submit" class="btn btn-primary" disabled="@(!Model.AllCourses.Any())">Enroll selected courses</button>
    <a asp-page="/Students/Enrollments" asp-route-id="@Model.Student.Id" class="btn btn-secondary">Cancel</a>
</form>
