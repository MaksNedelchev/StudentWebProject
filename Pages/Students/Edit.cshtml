@page "{id:int}"
@model StudentManagerWebApp.Pages.Students.EditModel
@{
}


<div class="row justify-content-center">
    <div class="col-md-6">
        <h2 class="mb-4">Edit student</h2>
        <form method="post">
            <input type="hidden" asp-for="Student.Id" />
            <input type="hidden" asp-for="Student.AppUserId" />
            <div class="mb-3">
                <label asp-for="Student.FirstName" class="form-label"></label>
                <input asp-for="Student.FirstName" class="form-control" />
                <span asp-validation-for="Student.FirstName" class="alert text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Student.LastName" class="form-label"></label>
                <input asp-for="Student.LastName" class="form-control" />
                <span asp-validation-for="Student.LastName" class="alert text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" type="email" class="form-control" />
                <span asp-validation-for="Email" class="alert text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Student.EnrollmentDate" class="form-label"></label>
                <input asp-for="Student.EnrollmentDate" min="2018-01-01" class="form-control" />
                <span asp-validation-for="Student.EnrollmentDate" class="alert text-danger"></span>
            </div>
            <button type="submit" class="btn btn-warning">Modify</button>
            <a asp-page="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>
